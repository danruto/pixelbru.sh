{
    "$schema": "https://biomejs.dev/schemas/2.2.5/schema.json",
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineEnding": "lf",
        "lineWidth": 120,
        "includes": [
            "**",
            "!**/node_modules/**",
            "!**/node_modules/**",
            "!**/dist/**",
            "!**/pnpm-lock.yaml",
            "!**/.direnv/**",
            "!**/.git/**",
            "!**/.netlify",
            "!**/.vercel",
            "!**/.vinxi",
            "!**/.next",
            "!**/biome.json"
        ]
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "noNonNullAssertion": "off"
            }
        },
        "includes": [
            "**",
            "!**/node_modules/**",
            "!**/node_modules/**",
            "!**/dist/**",
            "!**/pnpm-lock.yaml",
            "!**/.direnv/**",
            "!**/.git/**",
            "!**/.netlify",
            "!**/.vercel",
            "!**/.vinxi",
            "!**/.next",
            "!**/biome.json",
            "!**/components/ui/**",
            "!**/hooks/**",
            "!**/components/pb/icons.tsx"
        ]
    },
    "javascript": {
        "formatter": {
            "semicolons": "asNeeded"
        }
    }
}
