{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["typescript", "react", "nextjs", "jsx-a11y", "import", "unicorn"],
    "categories": {
        "correctness": "error",
        "suspicious": "warn"
    },
    "settings": {
        "next": {
            "rootDir": "."
        },
        "react": {
            "version": "19"
        }
    },
    "rules": {
        "react-in-jsx-scope": "off"
    },
    "ignorePatterns": [".next/", "node_modules/", "out/", "dist/", "components/ui/", "hooks/", "next-env.d.ts"]
}
